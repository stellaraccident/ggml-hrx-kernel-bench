    %a_qs2v = vector.load %a_i32_view[%a_qs_index2] : view<536870911xi32, #dense> -> vector<1xi32>
    %a_qs3v = vector.load %a_i32_view[%a_qs_index3] : view<536870911xi32, #dense> -> vector<1xi32>
