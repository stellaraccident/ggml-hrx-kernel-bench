    %a_f16_base = index.mul %a_block, %eightyeight : index
    %a_m_index = index.add %a_f16_base, %one : index
    %a_d_h = view.load %a_f16_view[%a_f16_base] : view<1073741824xf16, #dense> -> f16
    %a_m_h = view.load %a_f16_view[%a_m_index] : view<1073741824xf16, #dense> -> f16
    %a_d0 = scalar.extf %a_d_h : f16 to f32
    %a_m0 = scalar.extf %a_m_h : f16 to f32
    %scale_base = index.add %a_byte_base, %four : index
    %scale_group_lt4 = index.cmp ult, %scale_group, %four : index
    %scale_i32, %min_i32 = scf.if %scale_group_lt4 -> (i32, i32) {
      %d_index = index.add %scale_base, %scale_group : index
      %m_group = index.add %scale_group, %four : index
      %m_index = index.add %scale_base, %m_group : index
      %d_i8 = view.load %a_i8_view[%d_index] : view<2147483647xi8, #dense> -> i8
      %m_i8 = view.load %a_i8_view[%m_index] : view<2147483647xi8, #dense> -> i8
      %d_u32 = scalar.extui %d_i8 : i8 to i32
      %m_u32 = scalar.extui %m_i8 : i8 to i32
      %d = scalar.andi %d_u32, %mask_3f : i32
      %m = scalar.andi %m_u32, %mask_3f : i32
      scf.yield %d, %m : i32, i32
    } else {
      %group_minus4 = index.sub %scale_group, %four : index
      %group_plus4 = index.add %scale_group, %four : index
      %low_index = index.add %scale_base, %group_minus4 : index
      %mid_index = index.add %scale_base, %scale_group : index
      %high_index = index.add %scale_base, %group_plus4 : index
      %low_i8 = view.load %a_i8_view[%low_index] : view<2147483647xi8, #dense> -> i8
      %mid_i8 = view.load %a_i8_view[%mid_index] : view<2147483647xi8, #dense> -> i8
      %high_i8 = view.load %a_i8_view[%high_index] : view<2147483647xi8, #dense> -> i8
      %low = scalar.extui %low_i8 : i8 to i32
      %mid = scalar.extui %mid_i8 : i8 to i32
      %high = scalar.extui %high_i8 : i8 to i32
      %scale_low = scalar.andi %high, %mask_0f : i32
      %scale_hi0 = scalar.shrui %low, %six_i32 : i32
      %scale_hi = scalar.shli %scale_hi0, %four_i32 : i32
      %d = scalar.ori %scale_low, %scale_hi : i32
      %min_low = scalar.shrui %high, %four_i32 : i32
      %min_hi0 = scalar.shrui %mid, %six_i32 : i32
      %min_hi = scalar.shli %min_hi0, %four_i32 : i32
      %m = scalar.ori %min_low, %min_hi : i32
      scf.yield %d, %m : i32, i32
    }
    %scale_f32 = scalar.uitofp %scale_i32 : i32 to f32
    %min_f32 = scalar.uitofp %min_i32 : i32 to f32
    %a_d = scalar.mulf<reassoc|nnan|ninf|nsz> %a_d0, %scale_f32 : f32
    %a_m = scalar.mulf<reassoc|nnan|ninf|nsz> %a_m0, %min_f32 : f32

    %dot_vec0 = vector.dot4i<u8s8> %a_vec0, %b_vec0, %zero_i32v : vector<4xi8>, vector<4xi8>, vector<1xi32>
    %dot_vec1 = vector.dot4i<u8s8> %a_vec1, %b_vec1, %zero_i32v : vector<4xi8>, vector<4xi8>, vector<1xi32>
    %dot_vec2 = vector.dot4i<u8s8> %a_vec2, %b_vec2, %zero_i32v : vector<4xi8>, vector<4xi8>, vector<1xi32>
    %dot_vec3 = vector.dot4i<u8s8> %a_vec3, %b_vec3, %zero_i32v : vector<4xi8>, vector<4xi8>, vector<1xi32>
    %dot0 = vector.extract %dot_vec0[0] : vector<1xi32> -> i32
    %dot1 = vector.extract %dot_vec1[0] : vector<1xi32> -> i32
    %dot2 = vector.extract %dot_vec2[0] : vector<1xi32> -> i32
    %dot3 = vector.extract %dot_vec3[0] : vector<1xi32> -> i32
    %dot01 = scalar.addi %dot0, %dot1 : i32
    %dot23 = scalar.addi %dot2, %dot3 : i32
    %dot_i32 = scalar.addi %dot01, %dot23 : i32
    %dot_f32 = scalar.sitofp %dot_i32 : i32 to f32
    %scaled0 = scalar.mulf<reassoc|nnan|ninf|nsz> %b_d, %a_d : f32
    %scaled1 = scalar.mulf<reassoc|nnan|ninf|nsz> %scaled0, %dot_f32 : f32
    %half_sum = scalar.mulf<reassoc|nnan|ninf|nsz> %b_s, %half_f32 : f32
    %min_term = scalar.mulf<reassoc|nnan|ninf|nsz> %a_m, %half_sum : f32
    %value = scalar.subf<reassoc|nnan|ninf|nsz> %scaled1, %min_term : f32
    %next = scalar.addf<reassoc|nnan|ninf|nsz> %acc, %value : f32
    scf.yield %next : f32
  }

  %dot = kernel.subgroup.reduce<addf> %sum : f32
  %is_lane0 = index.cmp eq, %lane, %zero : index
  scf.if %is_lane0 {
    view.store %dot, %d_view[%row] : f32, view<1073741824xf32, #dense>
  }
  kernel.return
}
