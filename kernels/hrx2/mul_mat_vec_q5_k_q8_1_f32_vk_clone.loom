    %b_inner_f16_offset = index.mul %b_inner, %two : index
    %b_f16_base = index.add %b_f16_base0, %b_inner_f16_offset : index
    %b_s_index = index.add %b_f16_base, %one : index
    %b_d_h = view.load %b_f16_view[%b_f16_base] : view<1073741824xf16, #dense> -> f16
    %b_s_h = view.load %b_f16_view[%b_s_index] : view<1073741824xf16, #dense> -> f16
    %b_d = scalar.extf %b_d_h : f16 to f32
    %b_s = scalar.extf %b_s_h : f16 to f32

    %a_element = index.add %row_ncols, %col : index
    %a_block_idx = index.div %a_element, %thirtytwo : index
    %a_block = index.div %a_block_idx, %eight : index
    %a_group = index.rem %a_block_idx, %eight : index
    %a_iqs = index.mul %b_qs_idx, %four : index
    %iqs_k_base = index.mul %a_group, %eight : index
    %iqs_k = index.add %iqs_k_base, %a_iqs : index
    %scale_group = index.div %iqs_k, %eight : index
    %iqs_k_div16 = index.div %iqs_k, %sixteen : index
    %iqs_k_mod8 = index.rem %iqs_k, %eight : index
    %qs_idx_base = index.mul %iqs_k_div16, %eight : index
    %qs_idx = index.add %qs_idx_base, %iqs_k_mod8 : index
    %iqs_k_mod16 = index.rem %iqs_k, %sixteen : index
    %qs_shift_step = index.div %iqs_k_mod16, %eight : index
    %qs_shift_step_i32 = index.cast %qs_shift_step : index to i32
    %qs_shift = scalar.muli %qs_shift_step_i32, %four_i32 : i32
    %qh_shift_index = index.div %iqs_k, %eight : index
    %qh_shift = index.cast %qh_shift_index : index to i32

