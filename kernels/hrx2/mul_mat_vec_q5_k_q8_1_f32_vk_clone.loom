    %a_qs0 = vector.extract %a_qs0v[0] : vector<1xi32> -> i32
    %a_qs1 = vector.extract %a_qs1v[0] : vector<1xi32> -> i32
    %a_qs2 = vector.extract %a_qs2v[0] : vector<1xi32> -> i32
    %a_qs3 = vector.extract %a_qs3v[0] : vector<1xi32> -> i32
    %a_qh0 = vector.extract %a_qh0v[0] : vector<1xi32> -> i32
    %a_qh1 = vector.extract %a_qh1v[0] : vector<1xi32> -> i32
    %a_qh2 = vector.extract %a_qh2v[0] : vector<1xi32> -> i32
    %a_qh3 = vector.extract %a_qh3v[0] : vector<1xi32> -> i32
    %a_qs0_shifted = scalar.shrui %a_qs0, %qs_shift : i32
    %a_qs1_shifted = scalar.shrui %a_qs1, %qs_shift : i32
    %a_qs2_shifted = scalar.shrui %a_qs2, %qs_shift : i32
    %a_qs3_shifted = scalar.shrui %a_qs3, %qs_shift : i32
    %a_low0 = scalar.andi %a_qs0_shifted, %mask_0f0f0f0f : i32
    %a_low1 = scalar.andi %a_qs1_shifted, %mask_0f0f0f0f : i32
    %a_low2 = scalar.andi %a_qs2_shifted, %mask_0f0f0f0f : i32
    %a_low3 = scalar.andi %a_qs3_shifted, %mask_0f0f0f0f : i32
    %a_qh0_shifted = scalar.shrui %a_qh0, %qh_shift : i32
    %a_qh1_shifted = scalar.shrui %a_qh1, %qh_shift : i32
    %a_qh2_shifted = scalar.shrui %a_qh2, %qh_shift : i32
    %a_qh3_shifted = scalar.shrui %a_qh3, %qh_shift : i32
    %a_hi0_bits = scalar.andi %a_qh0_shifted, %mask_01010101 : i32
    %a_hi1_bits = scalar.andi %a_qh1_shifted, %mask_01010101 : i32
    %a_hi2_bits = scalar.andi %a_qh2_shifted, %mask_01010101 : i32
    %a_hi3_bits = scalar.andi %a_qh3_shifted, %mask_01010101 : i32
    %a_hi0 = scalar.shli %a_hi0_bits, %four_i32 : i32
    %a_hi1 = scalar.shli %a_hi1_bits, %four_i32 : i32
    %a_hi2 = scalar.shli %a_hi2_bits, %four_i32 : i32
    %a_hi3 = scalar.shli %a_hi3_bits, %four_i32 : i32
    %a_word0 = scalar.ori %a_low0, %a_hi0 : i32
    %a_word1 = scalar.ori %a_low1, %a_hi1 : i32
    %a_word2 = scalar.ori %a_low2, %a_hi2 : i32
