    %a_vec1 = vector.bitcast %a_vec_word1 : vector<1xi32> to vector<4xi8>
    %a_vec2 = vector.bitcast %a_vec_word2 : vector<1xi32> to vector<4xi8>
    %a_vec3 = vector.bitcast %a_vec_word3 : vector<1xi32> to vector<4xi8>

