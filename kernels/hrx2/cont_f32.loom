    %src_idx = index.assume %src_e3_raw [range(%src_e3_raw, 0, 1073741823)] : index
    %dst_idx = index.mul %linear_vec, %four : index
    %value = vector.load %src0_view[%src_idx] : view<1073741824xf32, #dense> -> vector<4xf32>
