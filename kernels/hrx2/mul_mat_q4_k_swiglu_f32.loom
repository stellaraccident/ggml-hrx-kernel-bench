    %x_q_f32 = scalar.uitofp %x_q_i32 : i32 to f32
    %gate_q_f32 = scalar.uitofp %gate_q_i32 : i32 to f32
    %x_scaled = scalar.mulf<reassoc|nnan|ninf|nsz> %x_d, %x_q_f32 : f32
