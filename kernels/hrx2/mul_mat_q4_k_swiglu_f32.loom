func.template<hrx2.q4_k_f32.accumulate_dual_block> priority(1) @q4_k_f32_accumulate_dual_block(%x_acc: f32, %gate_acc: f32, %src_x: buffer, %src_gate: buffer, %rhs: view<1073741824xf32, #dense>, %x_row_block_base: index, %gate_row_block_base: index, %src1_col_base: index, %block_idx: index, %group: index, %lane_q: index, %qs_lane_base: index) -> (f32, f32) {
