  %gate_block_byte_base = index.mul %gate_linear_block, %block_bytes : index
  %x_qs_payload = index.add %x_block_byte_base, %qs_offset : index
  %gate_qs_payload = index.add %gate_block_byte_base, %qs_offset : index
  %x_qs_base = index.add %x_qs_payload, %qs_lane_base : index
  %gate_qs_base = index.add %gate_qs_payload, %qs_lane_base : index
  %x_d, %x_min = func.apply<hrx2.q4_k_f32.block_params>(%src_x, %x_linear_block, %group) : (buffer, index, index) -> (f32, f32)
  %gate_d, %gate_min = func.apply<hrx2.q4_k_f32.block_params>(%src_gate, %gate_linear_block, %group) : (buffer, index, index) -> (f32, f32)
  %group_parity = index.rem %group, %two : index
  %is_high_group = index.cmp eq, %group_parity, %one : index
  %x_next, %gate_next = scf.for %j = [%zero_index to %four step %one](%x_inner = %x_acc : f32, %gate_inner = %gate_acc : f32) -> (f32, f32) {
    %x_q_index = index.add %x_qs_base, %j : index
    %gate_q_index = index.add %gate_qs_base, %j : index
    %src_offset = index.add %src_base, %j : index
    %src1_index = index.add %src1_col_base, %src_offset : index
    %x_q_i8 = view.load %src_x_i8_view[%x_q_index] : view<2147483647xi8, #dense> -> i8
    %gate_q_i8 = view.load %src_gate_i8_view[%gate_q_index] : view<2147483647xi8, #dense> -> i8
    %x_q_byte = scalar.extui %x_q_i8 : i8 to i32
    %gate_q_byte = scalar.extui %gate_q_i8 : i8 to i32
    %x_q_i32, %gate_q_i32 = scf.if %is_high_group -> (i32, i32) {
      %x_hi = scalar.shrui %x_q_byte, %four_i32 : i32
      %gate_hi = scalar.shrui %gate_q_byte, %four_i32 : i32
      scf.yield %x_hi, %gate_hi : i32, i32
    } else {
      %x_lo = scalar.andi %x_q_byte, %mask_0f : i32
