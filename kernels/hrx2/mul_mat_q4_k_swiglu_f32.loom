    %gate_acc_next = scalar.addf<reassoc|nnan|ninf|nsz> %gate_inner, %gate_product : f32
    scf.yield %x_acc_next, %gate_acc_next : f32, f32
  }
  func.return %x_next, %gate_next : f32, f32
}

