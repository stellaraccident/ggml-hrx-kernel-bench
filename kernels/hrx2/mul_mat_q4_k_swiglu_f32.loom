  %dst_global = buffer.assume.memory_space<global> %dst : buffer
  %src0_noalias, %src1_noalias, %dst_noalias = buffer.assume.noalias %src0_global, %src1_global, %dst_global : buffer, buffer, buffer
  %src1_view = buffer.view %src1_noalias[%base] : buffer -> view<1073741824xf32, #dense>
  %dst_view = buffer.view %dst_noalias[%base] : buffer -> view<[%dst_count]xf32, #dense>

  %gate_row = index.add %row, %rows_bounded : index
  %x_row_block_base = index.mul %row, %blocks_per_row : index
  %gate_row_block_base = index.mul %gate_row, %blocks_per_row : index
  %src1_col_base = index.mul %col, %k_bounded : index
  %x_sum, %gate_sum = scf.for %block_idx = [%block_slot to %blocks_per_row step %block_step](%x_acc = %zero_f32 : f32, %gate_acc = %zero_f32 : f32) -> (f32, f32) {
    %x_next = func.apply<hrx2.q4_k_f32.accumulate_block>(%x_acc, %src0_noalias, %src1_view, %x_row_block_base, %src1_col_base, %block_idx, %group, %lane_q, %qs_lane_base) : (f32, buffer, view<1073741824xf32, #dense>, index, index, index, index, index, index) -> (f32)
    %gate_next = func.apply<hrx2.q4_k_f32.accumulate_block>(%gate_acc, %src0_noalias, %src1_view, %gate_row_block_base, %src1_col_base, %block_idx, %group, %lane_q, %qs_lane_base) : (f32, buffer, view<1073741824xf32, #dense>, index, index, index, index, index, index) -> (f32)
    scf.yield %x_next, %gate_next : f32, f32
  }

  %x_dot = kernel.workgroup.reduce<addf> %x_sum : f32
  %gate_dot = kernel.workgroup.reduce<addf> %gate_sum : f32
  %dst_col_base = index.mul %col, %rows_bounded : index
  %dst_index = index.add %dst_col_base, %row : index
  %lane_i32 = index.cast %lane : index to i32
  %zero_i32 = scalar.constant 0 : i32
  %is_lane0 = scalar.cmpi eq, %lane_i32, %zero_i32 : i32
  scf.if %is_lane0 {
    %silu = scalar.siluf %x_dot : f32
    %result = scalar.mulf<nnan|ninf|nsz> %silu, %gate_dot : f32
    view.store %result, %dst_view[%dst_index] : f32, view<[%dst_count]xf32, #dense>
  }
  kernel.return
}
