    %scaled_negative = scalar.cmpi slt, %scaled_bits, %zero_i32 : i32
    %round_bias = scf.select %scaled_negative, %negative_half_f32, %half_f32 : f32
    %biased = scalar.addf<nnan|ninf|nsz> %scaled, %round_bias : f32
