  %dst_stride_ne2 = config.get @hrx2.shape.mul_mat_f16.dst_stride_ne2 : index
  %dst_stride_ne3 = config.get @hrx2.shape.mul_mat_f16.dst_stride_ne3 : index
  %src0_stride_row_elements = index.div %src0_stride_row, %two : index
  %src0_stride_ne2_elements = index.div %src0_stride_ne2, %two : index
  %src0_stride_ne3_elements = index.div %src0_stride_ne3, %two : index
  %src1_stride_col_elements = index.div %src1_stride_col, %four : index
  %src1_stride_ne2_elements = index.div %src1_stride_ne2, %four : index
  %src1_stride_ne3_elements = index.div %src1_stride_ne3, %four : index
  %dst_stride_col_elements = index.div %dst_stride_col, %four : index
  %dst_stride_ne2_elements = index.div %dst_stride_ne2, %four : index
  %dst_stride_ne3_elements = index.div %dst_stride_ne3, %four : index
  %k_bounded = index.assume %k [range(%k, 16, 8192), mul(%k, 16)] : index
  %rows_bounded = index.assume %rows [range(%rows, 64, 8192), mul(%rows, 64)] : index
  %cols_bounded = index.assume %cols [range(%cols, 64, 1024), mul(%cols, 64)] : index
  %col_tiles_round = index.add %cols_bounded, %sixty_three : index
  %col_tiles = index.div %col_tiles_round, %sixty_four : index
  %dst_layout = encoding.layout.strided [1, %rows_bounded] : encoding<layout>

  %row_tile0 = kernel.workgroup.id<x> : index
  %row_tile = index.assume %row_tile0 [range(%row_tile0, 0, 127)] : index
  %linear_y0 = kernel.workgroup.id<y> : index
  %linear_y = index.assume %linear_y0 [range(%linear_y0, 0, 4095)] : index
  %col_tile = index.rem %linear_y, %col_tiles : index
  %head_linear0 = index.div %linear_y, %col_tiles : index
  %head_linear = index.assume %head_linear0 [range(%head_linear0, 0, 4095)] : index
  %lane0 = kernel.workitem.id<x> : index
  %lane = index.assume %lane0 [range(%lane0, 0, 127)] : index
  %subgroup_id0 = kernel.subgroup.id : index
  %subgroup_id = index.assume %subgroup_id0 [range(%subgroup_id0, 0, 1)] : index

  %head = index.rem %head_linear, %dst_ne2 : index
  %batch = index.div %head_linear, %dst_ne2 : index
  %src0_group_scale2 = index.div %dst_ne2, %src0_ne2 : index
  %src0_i02 = index.div %head, %src0_group_scale2 : index
  %src0_group_scale3 = index.div %dst_ne3, %src0_ne3 : index
  %src0_i03 = index.div %batch, %src0_group_scale3 : index
  %row_tile_base0 = index.mul %row_tile, %sixty_four : index
  %row_tile_base = index.assume %row_tile_base0 [range(%row_tile_base0, 0, 8191), mul(%row_tile_base0, 16)] : index
  %col_tile_base0 = index.mul %col_tile, %sixty_four : index
  %col_quad_offset = index.mul %subgroup_id, %thirty_two : index
  %col_base0 = index.add %col_tile_base0, %col_quad_offset : index
  %col_base = index.assume %col_base0 [range(%col_base0, 0, 1023), mul(%col_base0, 16)] : index

  %src0_last_row = index.sub %rows_bounded, %unit : index
  %src0_last_row_off = index.mul %src0_last_row, %src0_stride_row_elements : index
  %src0_last_ne2 = index.sub %src0_ne2, %unit : index
  %src0_last_ne2_off = index.mul %src0_last_ne2, %src0_stride_ne2_elements : index
  %src0_last_ne3 = index.sub %src0_ne3, %unit : index
  %src0_last_ne3_off = index.mul %src0_last_ne3, %src0_stride_ne3_elements : index
  %src0_last_head_off = index.add %src0_last_row_off, %src0_last_ne2_off : index
  %src0_last_slice_off = index.add %src0_last_head_off, %src0_last_ne3_off : index
  %src0_count = index.add %src0_last_slice_off, %k_bounded : index
  %src1_last_col = index.sub %cols_bounded, %unit : index
  %src1_last_col_off = index.mul %src1_last_col, %src1_stride_col_elements : index
  %src1_last_ne2 = index.sub %dst_ne2, %unit : index
  %src1_last_ne2_off = index.mul %src1_last_ne2, %src1_stride_ne2_elements : index
  %src1_last_ne3 = index.sub %dst_ne3, %unit : index
  %src1_last_ne3_off = index.mul %src1_last_ne3, %src1_stride_ne3_elements : index
  %src1_last_head_off = index.add %src1_last_col_off, %src1_last_ne2_off : index
  %src1_last_slice_off = index.add %src1_last_head_off, %src1_last_ne3_off : index
  %src1_count = index.add %src1_last_slice_off, %k_bounded : index
  %dst_last_col = index.sub %cols_bounded, %unit : index
  %dst_last_col_off = index.mul %dst_last_col, %dst_stride_col_elements : index
  %dst_last_ne2 = index.sub %dst_ne2, %unit : index
  %dst_last_ne2_off = index.mul %dst_last_ne2, %dst_stride_ne2_elements : index
  %dst_last_ne3 = index.sub %dst_ne3, %unit : index
  %dst_last_ne3_off = index.mul %dst_last_ne3, %dst_stride_ne3_elements : index
  %dst_count_base0 = index.add %dst_last_col_off, %dst_last_ne2_off : index
  %dst_count_base1 = index.add %dst_count_base0, %dst_last_ne3_off : index
  %dst_count = index.add %dst_count_base1, %rows_bounded : index

  %src0_global = buffer.assume.memory_space<global> %src0 : buffer
  %src1_global = buffer.assume.memory_space<global> %src1 : buffer
  %dst_global = buffer.assume.memory_space<global> %dst : buffer
  %src0_aligned = buffer.assume.alignment %src0_global {minimum_alignment = 16} : buffer
  %src1_aligned = buffer.assume.alignment %src1_global {minimum_alignment = 16} : buffer
  %dst_aligned = buffer.assume.alignment %dst_global {minimum_alignment = 16} : buffer
  %src0_noalias, %src1_noalias, %dst_noalias = buffer.assume.noalias %src0_aligned, %src1_aligned, %dst_aligned : buffer, buffer, buffer
  %src0_view = buffer.view %src0_noalias[%base] : buffer -> view<[%src0_count]xf16, #dense>
  %src1_view = buffer.view %src1_noalias[%base] : buffer -> view<[%src1_count]xf32, #dense>

  %src0_group_elem = index.mul %src0_i02, %src0_stride_ne2_elements : index
  %src0_batch_elem = index.mul %src0_i03, %src0_stride_ne3_elements : index
  %src0_head_elem = index.add %src0_group_elem, %src0_batch_elem : index
  %src1_head_elem = index.mul %head, %src1_stride_ne2_elements : index
  %src1_batch_elem = index.mul %batch, %src1_stride_ne3_elements : index
  %src1_head_batch_elem = index.add %src1_head_elem, %src1_batch_elem : index
  %src1_col_tile_elem = index.mul %col_tile_base0, %src1_stride_col_elements : index
  %src1_tile_elem = index.add %src1_head_batch_elem, %src1_col_tile_elem : index
  %dst_head_elem = index.mul %head, %dst_stride_ne2_elements : index
  %dst_batch_elem = index.mul %batch, %dst_stride_ne3_elements : index
  %dst_head_batch_elem = index.add %dst_head_elem, %dst_batch_elem : index
  %dst_col_elem = index.mul %col_base, %dst_stride_col_elements : index
  %dst_base_elem0 = index.add %dst_head_batch_elem, %dst_col_elem : index
  %dst_elem = index.add %dst_base_elem0, %row_tile_base : index
  %dst_offset0 = index.scale %dst_elem, %four_bytes : index, offset -> offset
  %dst_offset = index.assume %dst_offset0 [mul(%dst_offset0, 16)] : offset
  %dst_view = buffer.view %dst_noalias[%dst_offset] : buffer -> view<64x32xf32, %dst_layout>

  %scratch = buffer.alloca %scratch_bytes {base_alignment = 16, memory_space = workgroup} : buffer
  %lhs_stage_flat = buffer.view %scratch[%base] : buffer -> view<1024xf16, #dense>
  %lhs_stage = buffer.view %scratch[%base] : buffer -> view<64x16xf16, %lhs_layout>
  %rhs_stage_flat = buffer.view %scratch[%rhs_base] : buffer -> view<1024xf16, #dense>
  %rhs_stage = buffer.view %scratch[%rhs_base] : buffer -> view<16x64xf16, %rhs_layout>
  %init_fragment = vector.fragment<init> %zero_acc shape [%sixteen, %sixteen] : vector<8xf16>

  %r00, %r01, %r10, %r11, %r20, %r21, %r30, %r31 =
    scf.for %kk = [%zero to %k_bounded step %sixteen](
        %acc00 = %init_fragment, %acc01 = %init_fragment,
        %acc10 = %init_fragment, %acc11 = %init_fragment,
        %acc20 = %init_fragment, %acc21 = %init_fragment,
        %acc30 = %init_fragment, %acc31 = %init_fragment :
        vector<8xf16>, vector<8xf16>,
        vector<8xf16>, vector<8xf16>,
        vector<8xf16>, vector<8xf16>,
        vector<8xf16>, vector<8xf16>) ->
        (vector<8xf16>, vector<8xf16>,
         vector<8xf16>, vector<8xf16>,
         vector<8xf16>, vector<8xf16>,
         vector<8xf16>, vector<8xf16>) {
    %lhs_i0 = index.mul %lane, %eight : index
    %lhs_i = index.assume %lhs_i0 [range(%lhs_i0, 0, 1023), mul(%lhs_i0, 8)] : index
    %lhs_k_inner = index.rem %lhs_i, %sixteen : index
    %lhs_row_inner = index.div %lhs_i, %sixteen : index
    %lhs_global_row = index.add %row_tile_base, %lhs_row_inner : index
    %lhs_row_elem = index.mul %lhs_global_row, %src0_stride_row_elements : index
    %lhs_base_elem0 = index.add %src0_head_elem, %lhs_row_elem : index
    %lhs_k = index.add %kk, %lhs_k_inner : index
    %lhs_elem0 = index.add %lhs_base_elem0, %lhs_k : index
    %src0_vector_limit = index.sub %src0_count, %seven : index
    %lhs_elem = index.assume %lhs_elem0 [lt(%lhs_elem0, %src0_vector_limit), mul(%lhs_elem0, 8)] : index
    %lhs_value = vector.load %src0_view[%lhs_elem] : view<[%src0_count]xf16, #dense> -> vector<8xf16>
    vector.store %lhs_value, %lhs_stage_flat[%lhs_i] : vector<8xf16>, view<1024xf16, #dense>

    %rhs_i0 = index.mul %lane, %eight : index
    %rhs_i = index.assume %rhs_i0 [range(%rhs_i0, 0, 1023), mul(%rhs_i0, 8)] : index
    %rhs_k_inner = index.rem %rhs_i, %sixteen : index
    %rhs_col_inner = index.div %rhs_i, %sixteen : index
    %rhs_col_elem = index.mul %rhs_col_inner, %src1_stride_col_elements : index
    %rhs_k = index.add %kk, %rhs_k_inner : index
    %rhs_elem_base = index.add %src1_tile_elem, %rhs_col_elem : index
    %rhs_elem0 = index.add %rhs_elem_base, %rhs_k : index
    %src1_vector_limit = index.sub %src1_count, %seven : index
    %rhs_elem = index.assume %rhs_elem0 [lt(%rhs_elem0, %src1_vector_limit), mul(%rhs_elem0, 8)] : index
    %rhs_value_f32 = vector.load %src1_view[%rhs_elem] : view<[%src1_count]xf32, #dense> -> vector<8xf32>
    %rhs_value = vector.fptrunc %rhs_value_f32 : vector<8xf32> to vector<8xf16>
    vector.store %rhs_value, %rhs_stage_flat[%rhs_i] : vector<8xf16>, view<1024xf16, #dense>
    kernel.barrier<workgroup> {ordering = acq_rel, scope = workgroup}

    %col_inner0 = index.add %col_quad_offset, %zero : index
    %col_inner1 = index.add %col_inner0, %sixteen : index
    %row0 = index.constant 0 : index
    %row1 = index.constant 16 : index
    %row2 = index.constant 32 : index
    %row3 = index.constant 48 : index

    %lhs0 = vector.fragment.load<lhs> %lhs_stage[%row0, %zero] shape [%sixteen, %sixteen] : view<64x16xf16, %lhs_layout> -> vector<16xf16>
    %rhs00 = vector.fragment.load<rhs> %rhs_stage[%zero, %col_inner0] shape [%sixteen, %sixteen] : view<16x64xf16, %rhs_layout> -> vector<16xf16>
    %next00 = vector.mma %lhs0, %rhs00, %acc00 : vector<16xf16>, vector<16xf16>, vector<8xf16>
    %rhs01 = vector.fragment.load<rhs> %rhs_stage[%zero, %col_inner1] shape [%sixteen, %sixteen] : view<16x64xf16, %rhs_layout> -> vector<16xf16>
    %next01 = vector.mma %lhs0, %rhs01, %acc01 : vector<16xf16>, vector<16xf16>, vector<8xf16>

    %lhs1 = vector.fragment.load<lhs> %lhs_stage[%row1, %zero] shape [%sixteen, %sixteen] : view<64x16xf16, %lhs_layout> -> vector<16xf16>
    %rhs10 = vector.fragment.load<rhs> %rhs_stage[%zero, %col_inner0] shape [%sixteen, %sixteen] : view<16x64xf16, %rhs_layout> -> vector<16xf16>
    %next10 = vector.mma %lhs1, %rhs10, %acc10 : vector<16xf16>, vector<16xf16>, vector<8xf16>
    %rhs11 = vector.fragment.load<rhs> %rhs_stage[%zero, %col_inner1] shape [%sixteen, %sixteen] : view<16x64xf16, %rhs_layout> -> vector<16xf16>
    %next11 = vector.mma %lhs1, %rhs11, %acc11 : vector<16xf16>, vector<16xf16>, vector<8xf16>

    %lhs2 = vector.fragment.load<lhs> %lhs_stage[%row2, %zero] shape [%sixteen, %sixteen] : view<64x16xf16, %lhs_layout> -> vector<16xf16>
    %rhs20 = vector.fragment.load<rhs> %rhs_stage[%zero, %col_inner0] shape [%sixteen, %sixteen] : view<16x64xf16, %rhs_layout> -> vector<16xf16>
    %next20 = vector.mma %lhs2, %rhs20, %acc20 : vector<16xf16>, vector<16xf16>, vector<8xf16>
    %rhs21 = vector.fragment.load<rhs> %rhs_stage[%zero, %col_inner1] shape [%sixteen, %sixteen] : view<16x64xf16, %rhs_layout> -> vector<16xf16>
    %next21 = vector.mma %lhs2, %rhs21, %acc21 : vector<16xf16>, vector<16xf16>, vector<8xf16>

    %lhs3 = vector.fragment.load<lhs> %lhs_stage[%row3, %zero] shape [%sixteen, %sixteen] : view<64x16xf16, %lhs_layout> -> vector<16xf16>
    %rhs30 = vector.fragment.load<rhs> %rhs_stage[%zero, %col_inner0] shape [%sixteen, %sixteen] : view<16x64xf16, %rhs_layout> -> vector<16xf16>
    %next30 = vector.mma %lhs3, %rhs30, %acc30 : vector<16xf16>, vector<16xf16>, vector<8xf16>
    %rhs31 = vector.fragment.load<rhs> %rhs_stage[%zero, %col_inner1] shape [%sixteen, %sixteen] : view<16x64xf16, %rhs_layout> -> vector<16xf16>
    %next31 = vector.mma %lhs3, %rhs31, %acc31 : vector<16xf16>, vector<16xf16>, vector<8xf16>
    kernel.barrier<workgroup> {ordering = acq_rel, scope = workgroup}
    scf.yield %next00, %next01, %next10, %next11, %next20, %next21, %next30, %next31 :
        vector<8xf16>, vector<8xf16>, vector<8xf16>, vector<8xf16>,
        vector<8xf16>, vector<8xf16>, vector<8xf16>, vector<8xf16>
  }

  vector.fragment.store<result> %r00, %dst_view[%zero, %zero] shape [%sixteen, %sixteen] : vector<8xf16>, view<64x32xf32, %dst_layout>
  vector.fragment.store<result> %r01, %dst_view[%zero, %sixteen] shape [%sixteen, %sixteen] : vector<8xf16>, view<64x32xf32, %dst_layout>
  vector.fragment.store<result> %r10, %dst_view[%sixteen, %zero] shape [%sixteen, %sixteen] : vector<8xf16>, view<64x32xf32, %dst_layout>
  vector.fragment.store<result> %r11, %dst_view[%sixteen, %sixteen] shape [%sixteen, %sixteen] : vector<8xf16>, view<64x32xf32, %dst_layout>
  vector.fragment.store<result> %r20, %dst_view[%thirty_two, %zero] shape [%sixteen, %sixteen] : vector<8xf16>, view<64x32xf32, %dst_layout>
  vector.fragment.store<result> %r21, %dst_view[%thirty_two, %sixteen] shape [%sixteen, %sixteen] : vector<8xf16>, view<64x32xf32, %dst_layout>
  vector.fragment.store<result> %r30, %dst_view[%forty_eight, %zero] shape [%sixteen, %sixteen] : vector<8xf16>, view<64x32xf32, %dst_layout>
  vector.fragment.store<result> %r31, %dst_view[%forty_eight, %sixteen] shape [%sixteen, %sixteen] : vector<8xf16>, view<64x32xf32, %dst_layout>
  kernel.return
}
