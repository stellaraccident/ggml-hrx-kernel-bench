      %qh_u32_u7 = scalar.extui %qh_i16_u7 : i16 to i32
      %ql_shifted_u7 = scalar.shrui %ql_u32_u7, %b_shift_a : i32
      %ql_bits_u7 = scalar.andi %ql_shifted_u7, %mask_0f0f : i32
      %qh_shifted_u7 = scalar.shrui %qh_u32_u7, %qh_shift_a : i32
      %qh_bits_u7 = scalar.andi %qh_shifted_u7, %mask_0303 : i32
      %qh_high_u7 = scalar.shli %qh_bits_u7, %four_i32 : i32
      %q_pair_u7 = scalar.ori %ql_bits_u7, %qh_high_u7 : i32
      %q0_u32_u7 = scalar.andi %q_pair_u7, %mask_ff : i32
      %q1_shifted_u7 = scalar.shrui %q_pair_u7, %eight_i32 : i32
      %q1_u32_u7 = scalar.andi %q1_shifted_u7, %mask_ff : i32
      %q0_i32_u7 = scalar.subi %q0_u32_u7, %thirty_two_i32 : i32
      %q1_i32_u7 = scalar.subi %q1_u32_u7, %thirty_two_i32 : i32
      %q0_f32_u7 = scalar.sitofp %q0_i32_u7 : i32 to f32
      %q1_f32_u7 = scalar.sitofp %q1_i32_u7 : i32 to f32
      %d0_u7 = scalar.extf %d_f16_u7 : f16 to f32
      %scale_f32_u7 = scalar.sitofp %scale_i8_u7 : i8 to f32
      %dscale_u7 = scalar.mulf<reassoc|nnan|ninf|nsz|contract> %d0_u7, %scale_f32_u7 : f32
      %dequant0_u7 = scalar.mulf<reassoc|nnan|ninf|nsz|contract> %dscale_u7, %q0_f32_u7 : f32
      %dequant1_u7 = scalar.mulf<reassoc|nnan|ninf|nsz|contract> %dscale_u7, %q1_f32_u7 : f32
      %dequant0_f16_u7 = scalar.fptrunc %dequant0_u7 : f32 to f16
      %dequant1_f16_u7 = scalar.fptrunc %dequant1_u7 : f32 to f16
      %pair01_u7 = vector.from_elements %dequant0_f16_u7, %dequant1_f16_u7 : vector<2xf16>
      %lhs_store_row0_u7 = index.mul %lhs_row_inner_u7, %forty : index
      %lhs_store_index0_u7 = index.add %lhs_store_row0_u7, %loadr_a_x2 : index
      vector.store %pair01_u7, %lhs_stage_flat[%lhs_store_index0_u7] : vector<2xf16>, view<2560xf16, #dense>

    %loadr_b = index.rem %lane, %four : index
    %loadc_b = index.div %lane, %four : index
    %loadr_b_x8 = index.mul %loadr_b, %eight : index

      %rhs_col_inner_u0 = index.add %loadc_b, %zero : index
      %rhs_global_col_u0 = index.add %col_tile_base, %rhs_col_inner_u0 : index
      %rhs_col_base_u0 = index.mul %rhs_global_col_u0, %k_bounded : index
      %rhs_k_u0 = index.add %kk_global, %loadr_b_x8 : index
      %rhs_index0_u0 = index.add %rhs_col_base_u0, %rhs_k_u0 : index
      %src1_vector_limit_u0 = index.sub %src1_count, %seven : index
      %rhs_index_u0 = index.assume %rhs_index0_u0 [lt(%rhs_index0_u0, %src1_vector_limit_u0)] : index
      %rhs_vec_u0 = vector.load %src1_view[%rhs_index_u0] : view<[%src1_count]xf32, #dense> -> vector<8xf32>
      %rhs_vec_f16_u0 = vector.fptrunc %rhs_vec_u0 : vector<8xf32> to vector<8xf16>
      %rhs_store_col0_u0 = index.mul %rhs_col_inner_u0, %forty : index
      %rhs_store_index0_u0 = index.add %rhs_store_col0_u0, %loadr_b_x8 : index
      vector.store %rhs_vec_f16_u0, %rhs_stage_flat[%rhs_store_index0_u0] : vector<8xf16>, view<2560xf16, #dense>

      %rhs_col_inner_u1 = index.add %loadc_b, %thirty_two : index
      %rhs_global_col_u1 = index.add %col_tile_base, %rhs_col_inner_u1 : index
      %rhs_col_u1_in_bounds = index.cmp ult, %rhs_global_col_u1, %cols_bounded : index
      %rhs_vec_u1 = scf.if %rhs_col_u1_in_bounds -> (vector<8xf32>) {
        %rhs_col_base_u1 = index.mul %rhs_global_col_u1, %k_bounded : index
        %rhs_k_u1 = index.add %kk_global, %loadr_b_x8 : index
        %rhs_index0_u1 = index.add %rhs_col_base_u1, %rhs_k_u1 : index
        %src1_vector_limit_u1 = index.sub %src1_count, %seven : index
        %rhs_index_u1 = index.assume %rhs_index0_u1 [lt(%rhs_index0_u1, %src1_vector_limit_u1)] : index
        %loaded_u1 = vector.load %src1_view[%rhs_index_u1] : view<[%src1_count]xf32, #dense> -> vector<8xf32>
        scf.yield %loaded_u1 : vector<8xf32>
      } else {
        scf.yield %zero_vec8f32 : vector<8xf32>
      }
      %rhs_vec_f16_u1 = vector.fptrunc %rhs_vec_u1 : vector<8xf32> to vector<8xf16>
      %rhs_store_col0_u1 = index.mul %rhs_col_inner_u1, %forty : index
      %rhs_store_index0_u1 = index.add %rhs_store_col0_u1, %loadr_b_x8 : index
      vector.store %rhs_vec_f16_u1, %rhs_stage_flat[%rhs_store_index0_u1] : vector<8xf16>, view<2560xf16, #dense>
    kernel.barrier<workgroup> {ordering = acq_rel, scope = workgroup}

    %next00, %next01, %next10, %next11, %next20, %next21, %next30, %next31 =
      scf.for %ki = [%zero to %thirty_two step %sixteen](
          %inner00 = %acc00, %inner01 = %acc01,
          %inner10 = %acc10, %inner11 = %acc11,
          %inner20 = %acc20, %inner21 = %acc21,
          %inner30 = %acc30, %inner31 = %acc31 :
          vector<8xf16>, vector<8xf16>,
          vector<8xf16>, vector<8xf16>,
          vector<8xf16>, vector<8xf16>,
          vector<8xf16>, vector<8xf16>) ->
          (vector<8xf16>, vector<8xf16>,
           vector<8xf16>, vector<8xf16>,
           vector<8xf16>, vector<8xf16>,
           vector<8xf16>, vector<8xf16>) unroll(%two) {
      %lhs_row0 = index.add %row_quad_offset, %zero : index
      %lhs_row1 = index.add %lhs_row0, %sixteen : index
      %lhs_row2 = index.add %lhs_row0, %thirty_two : index
      %lhs_row3 = index.add %lhs_row0, %forty_eight : index
      %rhs_col0 = index.add %col_quad_offset, %zero : index
      %rhs_col1 = index.add %rhs_col0, %sixteen : index
      %lhs0 = vector.fragment.load<lhs> %lhs_stage[%lhs_row0, %ki] shape [%sixteen, %sixteen] : view<64x32xf16, %lhs_layout> -> vector<16xf16>
      %rhs00 = vector.fragment.load<rhs> %rhs_stage[%ki, %rhs_col0] shape [%sixteen, %sixteen] : view<32x64xf16, %rhs_layout> -> vector<16xf16>
      %mma00 = vector.mma %lhs0, %rhs00, %inner00 : vector<16xf16>, vector<16xf16>, vector<8xf16>
      %rhs01 = vector.fragment.load<rhs> %rhs_stage[%ki, %rhs_col1] shape [%sixteen, %sixteen] : view<32x64xf16, %rhs_layout> -> vector<16xf16>
      %mma01 = vector.mma %lhs0, %rhs01, %inner01 : vector<16xf16>, vector<16xf16>, vector<8xf16>

      %lhs1 = vector.fragment.load<lhs> %lhs_stage[%lhs_row1, %ki] shape [%sixteen, %sixteen] : view<64x32xf16, %lhs_layout> -> vector<16xf16>
      %rhs10 = vector.fragment.load<rhs> %rhs_stage[%ki, %rhs_col0] shape [%sixteen, %sixteen] : view<32x64xf16, %rhs_layout> -> vector<16xf16>
      %mma10 = vector.mma %lhs1, %rhs10, %inner10 : vector<16xf16>, vector<16xf16>, vector<8xf16>
      %rhs11 = vector.fragment.load<rhs> %rhs_stage[%ki, %rhs_col1] shape [%sixteen, %sixteen] : view<32x64xf16, %rhs_layout> -> vector<16xf16>
      %mma11 = vector.mma %lhs1, %rhs11, %inner11 : vector<16xf16>, vector<16xf16>, vector<8xf16>

      %lhs2 = vector.fragment.load<lhs> %lhs_stage[%lhs_row2, %ki] shape [%sixteen, %sixteen] : view<64x32xf16, %lhs_layout> -> vector<16xf16>
      %rhs20 = vector.fragment.load<rhs> %rhs_stage[%ki, %rhs_col0] shape [%sixteen, %sixteen] : view<32x64xf16, %rhs_layout> -> vector<16xf16>
      %mma20 = vector.mma %lhs2, %rhs20, %inner20 : vector<16xf16>, vector<16xf16>, vector<8xf16>
      %rhs21 = vector.fragment.load<rhs> %rhs_stage[%ki, %rhs_col1] shape [%sixteen, %sixteen] : view<32x64xf16, %rhs_layout> -> vector<16xf16>
      %mma21 = vector.mma %lhs2, %rhs21, %inner21 : vector<16xf16>, vector<16xf16>, vector<8xf16>

      %lhs3 = vector.fragment.load<lhs> %lhs_stage[%lhs_row3, %ki] shape [%sixteen, %sixteen] : view<64x32xf16, %lhs_layout> -> vector<16xf16>
      %rhs30 = vector.fragment.load<rhs> %rhs_stage[%ki, %rhs_col0] shape [%sixteen, %sixteen] : view<32x64xf16, %rhs_layout> -> vector<16xf16>
      %mma30 = vector.mma %lhs3, %rhs30, %inner30 : vector<16xf16>, vector<16xf16>, vector<8xf16>
      %rhs31 = vector.fragment.load<rhs> %rhs_stage[%ki, %rhs_col1] shape [%sixteen, %sixteen] : view<32x64xf16, %rhs_layout> -> vector<16xf16>
      %mma31 = vector.mma %lhs3, %rhs31, %inner31 : vector<16xf16>, vector<16xf16>, vector<8xf16>

      scf.yield %mma00, %mma01, %mma10, %mma11,
          %mma20, %mma21, %mma30, %mma31 :
          vector<8xf16>, vector<8xf16>, vector<8xf16>, vector<8xf16>,
          vector<8xf16>, vector<8xf16>, vector<8xf16>, vector<8xf16>
    }
    kernel.barrier<workgroup> {ordering = acq_rel, scope = workgroup}
    scf.yield %next00, %next01, %next10, %next11,
        %next20, %next21, %next30, %next31 :
        vector<8xf16>, vector<8xf16>, vector<8xf16>, vector<8xf16>,
        vector<8xf16>, vector<8xf16>, vector<8xf16>, vector<8xf16>

  }

  scf.if %store_col_in_bounds {
    vector.fragment.store<result> %r00, %dst_view[%zero, %zero] shape [%sixteen, %sixteen] : vector<8xf16>, view<64x64xf32, %dst_layout>
    vector.fragment.store<result> %r01, %dst_view[%zero, %sixteen] shape [%sixteen, %sixteen] : vector<8xf16>, view<64x64xf32, %dst_layout>
    vector.fragment.store<result> %r10, %dst_view[%sixteen, %zero] shape [%sixteen, %sixteen] : vector<8xf16>, view<64x64xf32, %dst_layout>
    vector.fragment.store<result> %r11, %dst_view[%sixteen, %sixteen] shape [%sixteen, %sixteen] : vector<8xf16>, view<64x64xf32, %dst_layout>
    vector.fragment.store<result> %r20, %dst_view[%thirty_two, %zero] shape [%sixteen, %sixteen] : vector<8xf16>, view<64x64xf32, %dst_layout>
    vector.fragment.store<result> %r21, %dst_view[%thirty_two, %sixteen] shape [%sixteen, %sixteen] : vector<8xf16>, view<64x64xf32, %dst_layout>
    vector.fragment.store<result> %r30, %dst_view[%forty_eight, %zero] shape [%sixteen, %sixteen] : vector<8xf16>, view<64x64xf32, %dst_layout>
    vector.fragment.store<result> %r31, %dst_view[%forty_eight, %sixteen] shape [%sixteen, %sixteen] : vector<8xf16>, view<64x64xf32, %dst_layout>
  }
  kernel.return
}
